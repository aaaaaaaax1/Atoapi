{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atoapi",
  "version": "0.1.57",
  "identifier": "local.atoapi.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atoapi",
        "width": 1180,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"]
  }
}
